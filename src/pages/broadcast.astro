---
import BaseLayout from "../layouts/BaseLayout.astro";
import matchesData from "../data/matches.json";
import type { Match } from "../types";

const allMatches = matchesData.matches as Match[];

function getFlag(code: string) {
  const flags: Record<string, string> = {
    MEX:"🇲🇽",RSA:"🇿🇦",KOR:"🇰🇷",CZE:"🇨🇿",CAN:"🇨🇦",BIH:"🇧🇦",QAT:"🇶🇦",SUI:"🇨🇭",
    BRA:"🇧🇷",MAR:"🇲🇦",HAI:"🇭🇹",SCO:"🏴󠁧󠁢󠁳󠁣󠁴󠁿",USA:"🇺🇸",PAR:"🇵🇾",AUS:"🇦🇺",TUR:"🇹🇷",
    GER:"🇩🇪",CUW:"🇨🇼",CIV:"🇨🇮",ECU:"🇪🇨",NED:"🇳🇱",JPN:"🇯🇵",SWE:"🇸🇪",TUN:"🇹🇳",
    BEL:"🇧🇪",EGY:"🇪🇬",IRN:"🇮🇷",NZL:"🇳🇿",ESP:"🇪🇸",CPV:"🇨🇻",KSA:"🇸🇦",URU:"🇺🇾",
    FRA:"🇫🇷",SEN:"🇸🇳",IRQ:"🇮🇶",NOR:"🇳🇴",ARG:"🇦🇷",ALG:"🇩🇿",AUT:"🇦🇹",JOR:"🇯🇴",
    POR:"🇵🇹",COD:"🇨🇩",UZB:"🇺🇿",COL:"🇨🇴",ENG:"🏴󠁧󠁢󠁥󠁮󠁧󠁿",CRO:"🇭🇷",GHA:"🇬🇭",PAN:"🇵🇦"
  };
  return flags[code] || "🏳️";
}

function formatDate(dt: string) {
  return dt.slice(5, 16).replace("T", " ");
}
---

<BaseLayout title="直播计划">
  <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;margin-bottom:24px;">
    <div>
      <h1 style="font-size:22px;font-weight:700;margin:0 0 4px;">📺 直播计划</h1>
      <p style="color:var(--color-text-secondary);font-size:12px;margin:0;">央视 · 咪咕 · 抖音等多平台直播</p>
    </div>
    <a href="/WorldCup-2026.ics" download class="btn-primary">📅 下载赛程日历</a>
  </div>

  <!-- Platform legend -->
  <div style="display:flex;gap:12px;margin-bottom:20px;">
    <span style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--color-text-secondary);">
      <span style="width:8px;height:8px;border-radius:50%;background:#E53935;"></span> 央视CCTV5
    </span>
    <span style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--color-text-secondary);">
      <span style="width:8px;height:8px;border-radius:50%;background:#2196F3;"></span> 咪咕视频
    </span>
    <span style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--color-text-secondary);">
      <span style="width:8px;height:8px;border-radius:50%;background:#888;"></span> 抖音
    </span>
  </div>

  <!-- Match list with broadcast info -->
  <div style="display:flex;flex-direction:column;gap:8px;">
    {allMatches.filter(m => m.stage === "group" && m.round === 1).slice(0, 10).map(m => (
      <div class="glass-card" style="padding:14px 18px;">
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
          <span style="color:var(--color-accent);font-size:13px;font-weight:600;min-width:80px;">{formatDate(m.datetime)}</span>
          <span style="flex:1;display:flex;align-items:center;gap:8px;">
            <span>{getFlag(m.home.code)}</span>
            <span style="color:var(--color-text-primary);font-size:13px;font-weight:600;">{m.home.name}</span>
            <span style="color:var(--color-text-muted);font-size:12px;">VS</span>
            <span style="color:var(--color-text-primary);font-size:13px;font-weight:600;">{m.away.name}</span>
            <span>{getFlag(m.away.code)}</span>
          </span>
          <div style="display:flex;gap:6px;flex-wrap:wrap;">
            <span style="background:rgba(229,57,53,0.12);border-radius:6px;padding:4px 10px;color:#E53935;font-size:10px;border:1px solid rgba(229,57,53,0.2);">📺 CCTV5</span>
            <span style="background:rgba(33,150,243,0.08);border-radius:6px;padding:4px 10px;color:#2196F3;font-size:10px;border:1px solid rgba(33,150,243,0.15);">📱 咪咕</span>
            <span style="background:rgba(255,255,255,0.04);border-radius:6px;padding:4px 10px;color:#aaa;font-size:10px;border:1px solid rgba(255,255,255,0.06);">🎵 抖音</span>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Note -->
  <div class="glass-card" style="margin-top:16px;padding:16px;text-align:center;color:var(--color-text-muted);font-size:11px;">
    具体转播平台可能调整，请以赛前官方公告为准
  </div>
</BaseLayout>
