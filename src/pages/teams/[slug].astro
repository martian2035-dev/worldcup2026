---
import BaseLayout from "../../layouts/BaseLayout.astro";
import teamsData from "../../data/teams.json";
import playersData from "../../data/players.json";
import matchesData from "../../data/matches.json";
import type { Match } from "../../types";

export function getStaticPaths() {
  return teamsData.teams.map((t: any) => ({ params: { slug: t.code } }));
}

const { slug } = Astro.params;
const team = (teamsData.teams as any[]).find((t: any) => t.code === slug);
if (!team) {
  return new Response("球队未找到", { status: 404 });
}

const teamPlayers = (playersData.players as any[]).filter((p: any) => p.team === slug);
const starPlayers = teamPlayers.filter((p: any) => p.isStar);
const allMatches = (matchesData.matches as Match[]).filter(m =>
  m.home.code === slug || m.away.code === slug
).sort((a, b) => a.datetime.localeCompare(b.datetime));

function getFlag(code: string) {
  const flags: Record<string, string> = {
    MEX:"🇲🇽",RSA:"🇿🇦",KOR:"🇰🇷",CZE:"🇨🇿",CAN:"🇨🇦",BIH:"🇧🇦",QAT:"🇶🇦",SUI:"🇨🇭",
    BRA:"🇧🇷",MAR:"🇲🇦",HAI:"🇭🇹",SCO:"🏴󠁧󠁢󠁳󠁣󠁴󠁿",USA:"🇺🇸",PAR:"🇵🇾",AUS:"🇦🇺",TUR:"🇹🇷",
    GER:"🇩🇪",CUW:"🇨🇼",CIV:"🇨🇮",ECU:"🇪🇨",NED:"🇳🇱",JPN:"🇯🇵",SWE:"🇸🇪",TUN:"🇹🇳",
    BEL:"🇧🇪",EGY:"🇪🇬",IRN:"🇮🇷",NZL:"🇳🇿",ESP:"🇪🇸",CPV:"🇨🇻",KSA:"🇸🇦",URU:"🇺🇾",
    FRA:"🇫🇷",SEN:"🇸🇳",IRQ:"🇮🇶",NOR:"🇳🇴",ARG:"🇦🇷",ALG:"🇩🇿",AUT:"🇦🇹",JOR:"🇯🇴",
    POR:"🇵🇹",COD:"🇨🇩",UZB:"🇺🇿",COL:"🇨🇴",ENG:"🏴󠁧󠁢󠁥󠁮󠁧󠁿",CRO:"🇭🇷",GHA:"🇬🇭",PAN:"🇵🇦"
  };
  return flags[code] || "🏳️";
}

function formatTime(dt: string) { return dt.slice(5, 16).replace("T", " "); }

const positionLabels: Record<string, string> = {
  GK: "GK / 守门员", CB: "CB / 中后卫", LB: "LB / 左后卫", RB: "RB / 右后卫",
  CDM: "CDM / 防守中场", CM: "CM / 中前卫", CAM: "CAM / 前腰",
  LW: "LW / 左边锋", RW: "RW / 右边锋", ST: "ST / 前锋",
};

const positionOrder = ["GK", "CB", "LB", "RB", "CDM", "CM", "CAM", "LW", "RW", "ST"];

// 按位置分组的排序函数
function sortByPosition(players: any[]) {
  return [...players].sort((a, b) => {
    const ai = positionOrder.indexOf(a.position);
    const bi = positionOrder.indexOf(b.position);
    if (ai !== bi) return ai - bi;
    return a.number - b.number;
  });
}

// 按位置分组
function groupByPosition(players: any[]) {
  const groups: Record<string, any[]> = {};
  for (const pos of positionOrder) {
    const matched = players.filter((p: any) => p.position === pos);
    if (matched.length > 0) groups[pos] = matched;
  }
  return groups;
}

const coach = team.coach;
const isCoachObject = typeof coach === "object" && coach !== null;
const groupedPlayers = groupByPosition(teamPlayers);
const latestLineupMatch = [...allMatches].reverse().find(m => m.lineups && (m.home.code === slug || m.away.code === slug));
const latestLineup = latestLineupMatch
  ? latestLineupMatch.home.code === slug ? latestLineupMatch.lineups?.home : latestLineupMatch.lineups?.away
  : null;
const lineupRows = latestLineup
  ? [3, 2, 1, 0].map(code => latestLineup.starting.filter((p: any) => p.positionCode === code)).filter(row => row.length > 0)
  : [];
---

<BaseLayout title={`${team.name} - 球队详情`}>
  <!-- Hero -->
  <div style={`background:linear-gradient(135deg,${team.colors.primary}20,${team.colors.secondary}15);border-radius:16px;padding:28px;margin-bottom:20px;border:1px solid rgba(255,255,255,0.08);position:relative;overflow:hidden;`}>
    <div style="position:absolute;top:-30px;right:-20px;font-size:120px;opacity:0.06;">{getFlag(team.code)}</div>
    <div style="display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
      <span style="font-size:56px;">{getFlag(team.code)}</span>
      <div>
        <div style="font-size:24px;font-weight:800;">{team.name}</div>
        <div style="color:var(--color-text-secondary);font-size:12px;">
          {team.nameEn} · FIFA 排名 #{team.fifaRank || "?"} · {team.group}组
        </div>
        <div style="display:flex;gap:12px;margin-top:6px;flex-wrap:wrap;">
          {team.worldCups > 0 && <span style="color:var(--color-accent);font-size:11px;">⭐×{team.worldCups} 世界冠军</span>}
          <span style="color:var(--color-text-secondary);font-size:11px;">
            👥 {teamPlayers.length} 名球员
          </span>
        </div>
      </div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 300px;gap:20px;">

    <!-- 左列：球员阵容（按位置分组） -->
    <div>
      <!-- 阵容标题 -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
        <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;">
          完整阵容 · {teamPlayers.length} 人
        </div>
      </div>

      <!-- 按位置分组展示 -->
      {Object.entries(groupedPlayers).map(([pos, players]) => (
        <div style="margin-bottom:16px;">
          <div style="color:var(--color-accent);font-size:11px;font-weight:600;margin-bottom:6px;padding-bottom:4px;border-bottom:1px solid var(--color-border);">
            {positionLabels[pos] || pos}
            <span style="color:var(--color-text-muted);font-weight:400;margin-left:4px;">({players.length})</span>
          </div>
          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:6px;">
            {sortByPosition(players).map((p: any) => (
              <a href={`../../players/${p.id}/`} style="text-decoration:none;">
                <div class="glass-card" style="padding:10px 14px;display:flex;align-items:center;gap:10px;">
                  <span style="color:var(--color-accent);font-size:14px;font-weight:700;min-width:24px;text-align:center;">{p.number}</span>
                  <div style="flex:1;min-width:0;">
                    <div style="color:var(--color-text-primary);font-size:12px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{p.name}</div>
                    <div style="color:var(--color-text-muted);font-size:9px;margin-top:1px;">
                      {p.age ? `${p.age}岁` : ""}{p.height ? ` · ${p.height}cm` : ""}{p.weight ? ` · ${p.weight}kg` : ""}
                      {p.preferredFoot ? ` · ${p.preferredFoot}` : ""}
                    </div>
                  </div>
                  <div style="text-align:right;flex-shrink:0;">
                    <div style="color:var(--color-text-secondary);font-size:9px;">{p.club || ""}</div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- 右列：教练 + 明星球员 -->
    <div>
      <!-- 教练卡片 -->
      {isCoachObject && (
        <div class="glass-card" style="padding:16px;margin-bottom:16px;">
          <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;margin-bottom:10px;">👔 主教练</div>
          <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
            <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,rgba(255,215,0,0.2),rgba(67,160,71,0.1));display:flex;align-items:center;justify-content:center;font-size:20px;">
              👔
            </div>
            <div>
              <div style="color:var(--color-text-primary);font-size:14px;font-weight:700;">{coach.name}</div>
              {coach.nameEn && <div style="color:var(--color-text-muted);font-size:10px;">{coach.nameEn}</div>}
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:8px;text-align:center;">
              <div style="color:var(--color-accent);font-size:16px;font-weight:700;">{coach.nationality || "—"}</div>
              <div style="color:var(--color-text-muted);font-size:9px;">国籍</div>
            </div>
            <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:8px;text-align:center;">
              <div style="color:var(--color-text-primary);font-size:16px;font-weight:700;">{coach.age || "—"}</div>
              <div style="color:var(--color-text-muted);font-size:9px;">年龄</div>
            </div>
            <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:8px;text-align:center;">
              <div style="color:var(--color-text-primary);font-size:13px;font-weight:700;">{coach.since || "—"}</div>
              <div style="color:var(--color-text-muted);font-size:9px;">上任时间</div>
            </div>
            <div style="background:rgba(255,255,255,0.03);border-radius:8px;padding:8px;text-align:center;">
              <div style="color:var(--color-text-primary);font-size:14px;font-weight:700;">{team.group}组</div>
              <div style="color:var(--color-text-muted);font-size:9px;">所在小组</div>
            </div>
          </div>
        </div>
      )}

      {/* 最近比赛阵型 */}
      {latestLineup && (
        <div class="glass-card" style="padding:14px;margin-bottom:16px;">
          <div style="display:flex;justify-content:space-between;align-items:center;gap:8px;margin-bottom:10px;">
            <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;">最近比赛阵型</div>
            <div style="color:var(--color-accent);font-size:12px;font-weight:700;">{latestLineup.formation || "阵型待定"}</div>
          </div>
          <div style="color:var(--color-text-secondary);font-size:10px;margin-bottom:8px;">
            {latestLineupMatch?.home.name} vs {latestLineupMatch?.away.name}
          </div>
          <div style="background:linear-gradient(180deg,rgba(67,160,71,0.14),rgba(67,160,71,0.06));border:1px solid rgba(67,160,71,0.16);border-radius:8px;padding:8px;display:flex;flex-direction:column;gap:6px;">
            {lineupRows.map((row: any[]) => (
              <div style="display:flex;justify-content:center;gap:5px;flex-wrap:wrap;">
                {row.map((p: any) => (
                  <span style="max-width:86px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--color-text-primary);font-size:9px;background:rgba(0,0,0,0.18);border-radius:4px;padding:3px 5px;">
                    {p.number} {p.name}{p.captain ? " C" : ""}
                  </span>
                ))}
              </div>
            ))}
          </div>
          {latestLineup.substitutions.length > 0 && (
            <div style="margin-top:8px;display:flex;flex-direction:column;gap:3px;">
              {latestLineup.substitutions.slice(0, 5).map((sub: any) => (
                <div style="color:var(--color-text-secondary);font-size:10px;">
                  {sub.minute} {sub.playerOnName || "替补"} ← {sub.playerOffName || "下场"}
                </div>
              ))}
            </div>
          )}
        </div>
      )}

      {/* 明星球员 */}
      {starPlayers.length > 0 && (
        <div>
          <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;margin-bottom:10px;">⭐ 明星球员</div>
          {starPlayers.map((p: any) => (
            <a href={`../../players/${p.id}/`} style="text-decoration:none;">
              <div class="gold-card" style="padding:12px;margin-bottom:8px;">
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,rgba(255,215,0,0.2),rgba(67,160,71,0.1));display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">
                    👤
                  </div>
                  <div style="flex:1;min-width:0;">
                    <div style="color:var(--color-accent);font-size:13px;font-weight:700;">{p.name}</div>
                    <div style="color:var(--color-text-muted);font-size:9px;">
                      {positionLabels[p.position] || p.position} · {p.number}号
                      {p.club ? ` · ${p.club}` : ""}
                    </div>
                  </div>
                </div>
                <div style="display:flex;justify-content:space-around;margin-top:10px;padding-top:8px;border-top:1px solid var(--color-border);">
                  <div style="text-align:center;">
                    <div style="color:var(--color-text-primary);font-size:13px;font-weight:700;">{p.age || "—"}</div>
                    <div style="color:var(--color-text-muted);font-size:8px;">年龄</div>
                  </div>
                  <div style="text-align:center;">
                    <div style="color:var(--color-text-primary);font-size:13px;font-weight:700;">{p.height || "—"}cm</div>
                    <div style="color:var(--color-text-muted);font-size:8px;">身高</div>
                  </div>
                  <div style="text-align:center;">
                    <div style="color:var(--color-text-primary);font-size:13px;font-weight:700;">{p.weight || "—"}kg</div>
                    <div style="color:var(--color-text-muted);font-size:8px;">体重</div>
                  </div>
                  <div style="text-align:center;">
                    <div style="color:var(--color-text-primary);font-size:13px;font-weight:700;">{p.preferredFoot || "—"}</div>
                    <div style="color:var(--color-text-muted);font-size:8px;">惯用脚</div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      )}

      {/* 球队统计摘要 */}
      <div class="glass-card" style="padding:14px;margin-top:16px;">
        <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;margin-bottom:8px;">📊 球队概况</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
          <div style="text-align:center;padding:8px;background:rgba(255,255,255,0.03);border-radius:6px;">
            <div style="color:var(--color-accent);font-size:16px;font-weight:700;">#{team.fifaRank || "?"}</div>
            <div style="color:var(--color-text-muted);font-size:8px;">FIFA 排名</div>
          </div>
          <div style="text-align:center;padding:8px;background:rgba(255,255,255,0.03);border-radius:6px;">
            <div style="color:var(--color-text-primary);font-size:16px;font-weight:700;">{team.worldCups}</div>
            <div style="color:var(--color-text-muted);font-size:8px;">世界杯冠军</div>
          </div>
          <div style="text-align:center;padding:8px;background:rgba(255,255,255,0.03);border-radius:6px;">
            <div style="color:var(--color-text-primary);font-size:16px;font-weight:700;">{teamPlayers.length}</div>
            <div style="color:var(--color-text-muted);font-size:8px;">大名单人数</div>
          </div>
          <div style="text-align:center;padding:8px;background:rgba(255,255,255,0.03);border-radius:6px;">
            <div style="color:var(--color-text-primary);font-size:16px;font-weight:700;">{starPlayers.length}</div>
            <div style="color:var(--color-text-muted);font-size:8px;">明星球员</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 赛程 -->
  <div style="margin-top:24px;">
    <div style="color:var(--color-text-muted);font-size:10px;text-transform:uppercase;margin-bottom:8px;">📅 赛程</div>
    {allMatches.length > 0 ? (
      allMatches.map(m => (
        <div class="glass-card" style="padding:10px 14px;margin-bottom:6px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
          <span style="color:var(--color-accent);font-size:11px;min-width:80px;">{formatTime(m.datetime)}</span>
          <span style="flex:1;text-align:right;font-size:12px;color:var(--color-text-primary);min-width:80px;">{getFlag(m.home.code)} {m.home.name}</span>
          {m.score?.home !== null ? (
            <span style="min-width:40px;text-align:center;font-size:16px;font-weight:800;color:var(--color-text-primary);">{m.score!.home}-{m.score!.away}</span>
          ) : (
            <span style="min-width:40px;text-align:center;color:var(--color-text-muted);">VS</span>
          )}
          <span style="flex:1;font-size:12px;color:var(--color-text-primary);min-width:80px;">{m.away.name} {getFlag(m.away.code)}</span>
          <span style="color:var(--color-text-muted);font-size:10px;">{m.venue.name}</span>
        </div>
      ))
    ) : (
      <div class="glass-card" style="padding:16px;text-align:center;color:var(--color-text-muted);">暂无比赛</div>
    )}
  </div>
</BaseLayout>

<style>
  .gold-card {
    background: linear-gradient(135deg, rgba(255,215,0,0.08), rgba(255,215,0,0.02));
    border: 1px solid rgba(255,215,0,0.15);
    border-radius: 10px;
    transition: all 0.2s;
  }
  .gold-card:hover {
    background: linear-gradient(135deg, rgba(255,215,0,0.12), rgba(255,215,0,0.04));
    border-color: rgba(255,215,0,0.3);
  }
</style>
